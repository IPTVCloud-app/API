{
  "version": 2,
  "builds": [
    {
      "src": "src/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "src/API.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/API.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/cleanup",
      "schedule": "0 0 * * *"
    }
  ]
}